{
  "expo": {
    "name": "Avtale",
    "slug": "avtale",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "avtale",
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Avtale bruker Face ID for å beskytte kalenderen En Ny Dag."
        }
      ],
      "expo-speech-recognition"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "no.haugstulen.avtale",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "no.haugstulen.avtale"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94aa3e33-3262-46f1-9021-17582be7d5ae"
      }
    }
  }
}
