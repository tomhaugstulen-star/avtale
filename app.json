{
  "expo": {
    "name": "Avtale",
    "slug": "avtale",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "avtale",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Avtale bruker Face ID for å beskytte kalenderen En Ny Dag."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "no.haugstulen.avtale",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Avtale kobler til kalenderen på PC-en din når begge enhetene er på samme nettverk.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "no.haugstulen.avtale"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94aa3e33-3262-46f1-9021-17582be7d5ae"
      }
    }
  }
}
